KEY = your_encryption_key

# For SQL_SERVER variable
# Local -> Name of your SSMS server (ex: DESKTOP-ABC\SQLEXPRESS)
# Docker -> Just write a name you want, doesn't matter

# For the SQL_TABLES_TO_MERGE variable
# Because of a Bug in SAC to get the dates, write the fact tables names you want access dates

SQL_SERVER = find_name_in_sql-server-management-studio_field_"server-name"_when-connecting
SQL_PASSWORD = your_password
SQL_DATABASE = your_db_name
SQL_TABLES = your_dimensions_and_fact_tables
SQL_TABLES_TO_MERGE = the_fact_tables_you_want_to_get_the_dates
KNIME_API_ID = your_API_id
KNIME_API_PASSWORD = your_API_password